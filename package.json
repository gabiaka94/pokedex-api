{
  "name": "pokedex-api",
  "version": "1.0.0",
  "description": "A fun Pokedex REST API with translated Pokemon descriptions",
  "main": "dist/server.js",
  "homepage": "https://github.com/gabiaka94/pokedex-api#readme",
  "bugs": {
    "url": "https://github.com/gabiaka94/pokedex-api/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gabiaka94/pokedex-api.git"
  },
  "license": "ISC",
  "author": "Gabriele Miano",
  "scripts": {
    "dev": "ts-node src/server.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "test": "jest",
    "test:coverage": "jest --coverage",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "dependencies": {
    "axios": "^1.17.0",
    "express": "^5.2.1",
    "swagger-jsdoc": "^6.3.0",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.9.3",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "eslint": "^10.5.0",
    "jest": "^30.4.2",
    "prettier": "^3.8.4",
    "supertest": "^7.2.2",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  }
}
